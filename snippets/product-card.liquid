{%- assign product_brand = product.tags | first -%}
{%- assign mf_score = product.metafields.custom.conditie_score.value | plus: 0 -%}
{%- assign score_int = mf_score | floor -%}
{%- capture tags_handleized -%}{%- for tag in product.tags -%}{{ tag | handleize }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}{%- endcapture -%}
<div class="product-card" data-tags="{{ tags_handleized }}" data-score="{{ score_int }}" data-level="{{ product.metafields.custom.level | handleize | default: 'beginner' }}">
  <a href="{{ product.url }}" class="product-img">
    {%- if product.available -%}
      <span class="product-badge badge-available">Beschikbaar</span>
    {%- else -%}
      <span class="product-badge badge-sold-out">Uitverkocht</span>
    {%- endif -%}
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy">
    {%- else -%}
      <svg class="no-image" viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="10" y="2" width="40" height="48" rx="20" fill="currentColor" opacity="0.4"/>
        <line x1="15" y1="14" x2="45" y2="14" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        <line x1="15" y1="22" x2="45" y2="22" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        <line x1="15" y1="30" x2="45" y2="30" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        <line x1="32" y1="3" x2="32" y2="48" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
        <rect x="27" y="50" width="6" height="24" rx="3" fill="currentColor" opacity="0.5"/>
        <rect x="19" y="72" width="22" height="5" rx="2.5" fill="currentColor" opacity="0.4"/>
      </svg>
    {%- endif -%}
  </a>
  <div class="product-body">
    <div class="product-brand">{{ product_brand }}</div>
    <div class="product-name">{{ product.title }}</div>
    {%- if mf_score > 0 -%}
      <div class="pc-score">
        {%- for i in (1..5) -%}
          {%- assign i_half = i | minus: 0.5 -%}
          {%- if mf_score >= i -%}
            <span class="pc-ball pc-ball--on"></span>
          {%- elsif mf_score >= i_half -%}
            <span class="pc-ball pc-ball--half"></span>
          {%- else -%}
            <span class="pc-ball"></span>
          {%- endif -%}
        {%- endfor -%}
        <span class="pc-score-label">{{ mf_score }}/5</span>
      </div>
    {%- endif -%}
    <div class="product-tags">
      {%- for tag in product.tags offset: 1 limit: 3 -%}
        <span class="product-tag">{{ tag }}</span>
      {%- endfor -%}
    </div>
    <div class="product-footer">
      <div class="product-price-wrap">
        <span class="product-price">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="product-price-original">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
      {%- if product.available -%}
        <button class="add-to-cart-btn"
          data-add-to-cart="{{ product.selected_or_first_available_variant.id }}"
          data-product-title="{{ product.title | escape }}"
          data-variant-id="{{ product.selected_or_first_available_variant.id }}">
          + Voeg toe
        </button>
      {%- else -%}
        <button class="add-to-cart-btn" disabled>Uitverkocht</button>
      {%- endif -%}
    </div>
  </div>
</div>
