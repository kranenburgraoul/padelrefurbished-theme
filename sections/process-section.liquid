<section class="process-section">
  <div class="container">
    <div class="process-header">
      <div class="section-label">{{ section.settings.eyebrow }}</div>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subtext }}</p>
    </div>
    <div class="process-steps">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="process-step" {{ block.shopify_attributes }}>
            <div class="step-num" style="width:54px;height:54px;border-radius:50%;background:#2E69DD;color:white;font-size:1.2rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;position:relative;z-index:1;">{{ forloop.index }}</div>
            <h3 class="step-title">{{ block.settings.title }}</h3>
            <p class="step-text">{{ block.settings.text }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="process-step">
          <div class="step-num" style="width:54px;height:54px;border-radius:50%;background:#2E69DD;color:white;font-size:1.2rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;position:relative;z-index:1;">1</div>
          <h3 class="step-title">Inspectie</h3>
          <p class="step-text">We beoordelen elk racket op beschadigingen, structuur en algehele speelkwaliteit.</p>
        </div>
        <div class="process-step">
          <div class="step-num" style="width:54px;height:54px;border-radius:50%;background:#2E69DD;color:white;font-size:1.2rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;position:relative;z-index:1;">2</div>
          <h3 class="step-title">Reiniging & Grip</h3>
          <p class="step-text">Het racket wordt grondig gereinigd en voorzien van een gloednieuwe grip.</p>
        </div>
        <div class="process-step">
          <div class="step-num" style="width:54px;height:54px;border-radius:50%;background:#2E69DD;color:white;font-size:1.2rem;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;position:relative;z-index:1;">3</div>
          <h3 class="step-title">Klaar om te spelen</h3>
          <p class="step-text">Getest, goedgekeurd en zorgvuldig verpakt. Jouw racket is klaar voor het veld.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Werkwijze",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Label boven titel",
      "default": "Hoe het werkt"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Ons refurbishment proces"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "Elk racket doorloopt een zorgvuldig kwaliteitsproces voordat het bij jou arriveert."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Stap",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Inspectie"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Tekst",
          "default": "We beoordelen elk racket op beschadigingen, structuur en algehele speelkwaliteit."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Werkwijze",
      "blocks": [
        { "type": "step", "settings": { "title": "Inspectie", "text": "We beoordelen elk racket op beschadigingen, structuur en algehele speelkwaliteit." } },
        { "type": "step", "settings": { "title": "Reiniging & Grip", "text": "Het racket wordt grondig gereinigd en voorzien van een gloednieuwe grip." } },
        { "type": "step", "settings": { "title": "Klaar om te spelen", "text": "Getest, goedgekeurd en zorgvuldig verpakt. Jouw racket is klaar voor het veld." } }
      ]
    }
  ]
}
{% endschema %}
