<section class="faq-section section-py">
  <div class="container">
    <div class="faq-header">
      <div class="section-label">{{ section.settings.eyebrow }}</div>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subtext != blank -%}
        <p class="section-subtitle" style="margin-top:0.75rem;">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>
    <div class="faq-grid">
      {%- for block in section.blocks -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <div class="faq-question" data-faq-trigger>
            {{ block.settings.question }}
            <svg class="faq-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9l6 6 6-6"/>
            </svg>
          </div>
          <div class="faq-answer">
            <div class="faq-answer-inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Label boven titel", "default": "Veelgestelde vragen" },
    { "type": "text", "id": "heading", "label": "Koptekst", "default": "Heb je een vraag?" },
    { "type": "text", "id": "subtext", "label": "Ondertekst", "default": "Misschien staat je antwoord hier al." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Vraag & antwoord",
      "settings": [
        { "type": "text", "id": "question", "label": "Vraag", "default": "Wat is een refurbished racket precies?" },
        { "type": "textarea", "id": "answer", "label": "Antwoord", "default": "Een refurbished racket is een gebruikt racket dat professioneel is geïnspecteerd, gereinigd en voorzien van een nieuwe grip." }
      ]
    }
  ],
  "presets": [
    { "name": "FAQ" }
  ]
}
{% endschema %}
