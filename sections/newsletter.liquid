<section class="newsletter-section">
  <div class="container">
    <div class="newsletter-inner">
      <div class="newsletter-text">
        <div class="section-label">{{ section.settings.eyebrow }}</div>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subtext }}</p>
      </div>
      {%- form 'customer', id: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ section.settings.placeholder }}"
            required
            class="newsletter-input"
            aria-label="E-mailadres">
          <button type="submit" class="btn btn-white">{{ section.settings.button_label }}</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p style="color:rgba(255,255,255,0.8);margin-top:0.75rem;font-size:0.9rem;">✓ Bedankt voor je aanmelding!</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nieuwsbrief",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Label boven titel",
      "default": "Nieuwsbrief"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Gratis grip bij aanmelding"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "Ontvang updates over nieuwe rackets en exclusieve aanbiedingen."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Invoerveld placeholder",
      "default": "jouw@email.nl"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knop tekst",
      "default": "Aanmelden →"
    }
  ],
  "presets": [
    {
      "name": "Nieuwsbrief"
    }
  ]
}
{% endschema %}
