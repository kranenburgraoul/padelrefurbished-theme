<div class="filter-bar">
  <div class="filter-inner">
    <div class="filter-groups">
      <span class="filter-label">Merk</span>
      <div class="filter-chips">
        <button class="filter-chip active" data-filter="all" data-filter-group="brand">Alle merken</button>
        {%- for tag in collection.all_tags -%}
          {%- if tag contains 'merk:' -%}
            <button class="filter-chip" data-filter="{{ tag | remove: 'merk:' | handleize }}" data-filter-group="brand">
              {{ tag | remove: 'merk:' }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <span class="filter-label" style="margin-left:1rem;">Niveau</span>
      <div class="filter-chips">
        <button class="filter-chip active" data-filter="all" data-filter-group="level">Alle niveaus</button>
        {%- for tag in collection.all_tags -%}
          {%- if tag contains 'niveau:' -%}
            <button class="filter-chip" data-filter="{{ tag | remove: 'niveau:' | handleize }}" data-filter-group="level">
              {{ tag | remove: 'niveau:' }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    <span class="filter-count">{{ collection.products_count }} rackets</span>
  </div>
</div>

<section class="catalog-section">
  <div class="container">
    <div class="catalog-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p style="grid-column:1/-1;text-align:center;padding:3rem;color:#6B7280;">Geen producten gevonden.</p>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}
      <div class="pagination" style="text-align:center;margin-top:3rem;">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collectie raster",
  "settings": [],
  "presets": [
    {
      "name": "Collectie raster"
    }
  ]
}
{% endschema %}
