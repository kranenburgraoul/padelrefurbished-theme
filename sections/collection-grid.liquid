{% paginate collection.products by 20 %}

<div class="filter-bar" id="filter-bar">
  <div class="filter-inner">

    <!-- Toolbar: altijd zichtbaar op mobiel -->
    <div class="filter-toolbar">
      <button class="filter-toggle-btn" id="filter-toggle" aria-expanded="false" aria-controls="filter-collapsible">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="21" y2="12"/><line x1="9" y1="18" x2="21" y2="18"/></svg>
        Filters
      </button>
      <!-- Alleen zichtbaar op mobiel -->
      <div class="filter-right filter-right--mobile">
        <span class="filter-count">{{ collection.products_count }} rackets</span>
        <select class="sort-select" onchange="window.location.href=this.value" aria-label="Sorteren">
          <option value="{{ collection.url }}"{% if collection.sort_by == blank or collection.sort_by == 'manual' %} selected{% endif %}>Aanbevolen</option>
          <option value="{{ collection.url }}?sort_by=price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>Prijs: laag → hoog</option>
          <option value="{{ collection.url }}?sort_by=price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>Prijs: hoog → laag</option>
        </select>
      </div>
    </div>

    <!-- Collapsible filters -->
    <div class="filter-collapsible" id="filter-collapsible">
      <div class="filter-groups">
        <span class="filter-label">Merk</span>
        <div class="filter-chips">
          <button class="filter-chip active" data-filter="all" data-filter-group="brand">Alle merken</button>
          {%- for tag in collection.all_tags -%}
            <button class="filter-chip" data-filter="{{ tag | handleize }}" data-filter-group="brand">
              {{ tag }}
            </button>
          {%- endfor -%}
        </div>
        <!-- Alleen zichtbaar op desktop: count + sort rechts in dezelfde rij -->
        <div class="filter-right filter-right--desktop">
          <span class="filter-count">{{ collection.products_count }} rackets</span>
          <select class="sort-select" onchange="window.location.href=this.value" aria-label="Sorteren">
            <option value="{{ collection.url }}"{% if collection.sort_by == blank or collection.sort_by == 'manual' %} selected{% endif %}>Aanbevolen</option>
            <option value="{{ collection.url }}?sort_by=price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>Prijs: laag → hoog</option>
            <option value="{{ collection.url }}?sort_by=price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>Prijs: hoog → laag</option>
          </select>
        </div>
      </div>
      <div class="filter-bottom">
        <span class="filter-label">Minimale conditie</span>
        <div class="score-slider-wrap">
          <span class="score-slider-edge">Alle</span>
          <input type="range" class="score-slider" id="score-slider" min="0" max="5" step="1" value="0" aria-label="Minimale conditiescore">
          <span class="score-slider-edge">5/5</span>
          <span class="score-slider-val" id="score-slider-val">Alle conditie</span>
        </div>
      </div>
    </div>

  </div>
</div>

<section class="catalog-section">
  <div class="container">
    <div class="catalog-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p style="grid-column:1/-1;text-align:center;padding:3rem;color:#6B7280;">Geen producten gevonden.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {{ paginate | default_pagination }}
    {%- endif -%}
  </div>
</section>

{% endpaginate %}

{% schema %}
{
  "name": "Collectie raster",
  "settings": [],
  "presets": [
    { "name": "Collectie raster" }
  ]
}
{% endschema %}
