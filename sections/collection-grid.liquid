{% paginate collection.products by 12 %}

<div class="filter-bar">
  <div class="filter-inner">
    <div class="filter-groups">
      <span class="filter-label">Merk</span>
      <div class="filter-chips">
        <button class="filter-chip active" data-filter="all" data-filter-group="brand">Alle merken</button>
        {%- for tag in collection.all_tags -%}
          <button class="filter-chip" data-filter="{{ tag | handleize }}" data-filter-group="brand">
            {{ tag }}
          </button>
        {%- endfor -%}
      </div>
    </div>
    <div class="filter-right">
      <span class="filter-count" id="filter-count">{{ collection.products_count }} rackets</span>
      <select class="sort-select" onchange="window.location.href=this.value" aria-label="Sorteren">
        <option value="{{ collection.url }}"{% if collection.sort_by == blank or collection.sort_by == 'manual' %} selected{% endif %}>Aanbevolen</option>
        <option value="{{ collection.url }}?sort_by=price-ascending"{% if collection.sort_by == 'price-ascending' %} selected{% endif %}>Prijs: laag → hoog</option>
        <option value="{{ collection.url }}?sort_by=price-descending"{% if collection.sort_by == 'price-descending' %} selected{% endif %}>Prijs: hoog → laag</option>
      </select>
    </div>
  </div>
</div>

<section class="catalog-section">
  <div class="container">
    <div class="catalog-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product -%}
      {%- else -%}
        <p style="grid-column:1/-1;text-align:center;padding:3rem;color:#6B7280;">Geen producten gevonden.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      {{ paginate | default_pagination }}
    {%- endif -%}
  </div>
</section>

{% endpaginate %}

{% schema %}
{
  "name": "Collectie raster",
  "settings": [],
  "presets": [
    { "name": "Collectie raster" }
  ]
}
{% endschema %}
