<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href="{{ routes.root_url }}" class="footer-logo-link">Padel<span>Refurbished</span></a>
        <div class="footer-slogan">{{ settings.slogan }}</div>
        <p class="footer-desc">{{ section.settings.description }}</p>
        <div class="footer-socials">
          {%- if settings.instagram_url != blank -%}
            <a href="{{ settings.instagram_url }}" target="_blank" rel="noopener" class="social-icon" aria-label="Instagram">IG</a>
          {%- endif -%}
          {%- if settings.facebook_url != blank -%}
            <a href="{{ settings.facebook_url }}" target="_blank" rel="noopener" class="social-icon" aria-label="Facebook">FB</a>
          {%- endif -%}
          {%- if settings.linkedin_url != blank -%}
            <a href="{{ settings.linkedin_url }}" target="_blank" rel="noopener" class="social-icon" aria-label="LinkedIn">in</a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu_column' -%}
          <div {{ block.shopify_attributes }}>
            <div class="footer-col-title">{{ block.settings.heading }}</div>
            <ul class="footer-links">
              {%- for link in linklists[block.settings.menu].links -%}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} PadelRefurbished. Alle rechten voorbehouden.</p>
      <p class="footer-kvk">KVK: {{ settings.kvk_number }} &nbsp;·&nbsp; BTW: {{ settings.btw_number }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "description",
      "label": "Beschrijving",
      "default": "Wij maken padel toegankelijk en duurzaam. Professioneel gereviseerde rackets voor elke speler — opgericht door studenten van Hogeschool Leiden."
    }
  ],
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menukolom",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Koptekst"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "Navigatie" } },
        { "type": "menu_column", "settings": { "heading": "Informatie" } }
      ]
    }
  ]
}
{% endschema %}
