<section class="about-team section">
  <div class="container">
    <div class="section-header" data-reveal>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subtext }}</p>
    </div>
    <div class="team-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="team-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <div class="team-card__photo">
                <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
              </div>
            {%- else -%}
              <div class="team-card__avatar">{{ block.settings.name | slice: 0 }}</div>
            {%- endif -%}
            <div class="team-card__body">
              <h3>{{ block.settings.name }}</h3>
              <span class="team-card__role">{{ block.settings.role }}</span>
              <p>{{ block.settings.bio }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- assign default_members = "Joep,Joey,Raoul,Mees" | split: "," -%}
        {%- assign default_roles = "Inkoop & kwaliteit,Klantervaring & logistiek,Marketing & online,Financiën & partnerships" | split: "," -%}
        {%- assign default_bios = "Verantwoordelijk voor inkoop en kwaliteitscontrole.,Zorgt voor een vlekkeloze klantervaring en logistiek.,Stuurt marketing en online aanwezigheid aan.,Beheert de financiën en partnerships." | split: "," -%}
        {%- for name in default_members -%}
          <div class="team-card">
            <div class="team-card__avatar" style="background:#DCE9FD;color:#2E69DD;font-weight:700;font-size:2.5rem;">{{ name | slice: 0 }}</div>
            <div class="team-card__body">
              <h3>{{ name }}</h3>
              <span class="team-card__role" style="color:#2E69DD;">Mede-oprichter</span>
              <p>{{ default_roles[forloop.index0] }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Team sectie",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Het team"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "De mensen achter PadelRefurbished"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Teamlid",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Naam",
          "default": "Naam"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Functie",
          "default": "Mede-oprichter"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Bio"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team sectie",
      "blocks": [
        { "type": "member", "settings": { "name": "Joep", "role": "Mede-oprichter" } },
        { "type": "member", "settings": { "name": "Joey", "role": "Mede-oprichter" } },
        { "type": "member", "settings": { "name": "Raoul", "role": "Mede-oprichter" } },
        { "type": "member", "settings": { "name": "Mees", "role": "Mede-oprichter" } }
      ]
    }
  ]
}
{% endschema %}
