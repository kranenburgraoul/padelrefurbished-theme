<section class="about-team section">
  <div class="container">
    <div class="section-header" data-reveal>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subtext }}</p>
    </div>
    <div class="team-grid">
      {%- for block in section.blocks -%}
        <div class="team-card" {{ block.shopify_attributes }} data-reveal>
          {%- if block.settings.image != blank -%}
            <div class="team-card__photo">
              <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            </div>
          {%- else -%}
            <div class="team-card__avatar">{{ block.settings.name | slice: 0 }}</div>
          {%- endif -%}
          <div class="team-card__body">
            <h3>{{ block.settings.name }}</h3>
            <span class="team-card__role">{{ block.settings.role }}</span>
            <p>{{ block.settings.bio }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Team sectie",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Het team"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "De mensen achter PadelRefurbished"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Teamlid",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Naam",
          "default": "Naam"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Functie",
          "default": "Mede-oprichter"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Bio"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team sectie",
      "blocks": [
        { "type": "member", "settings": { "name": "Joep", "role": "Mede-oprichter" } },
        { "type": "member", "settings": { "name": "Joey", "role": "Mede-oprichter" } },
        { "type": "member", "settings": { "name": "Raoul", "role": "Mede-oprichter" } },
        { "type": "member", "settings": { "name": "Mees", "role": "Mede-oprichter" } }
      ]
    }
  ]
}
{% endschema %}
