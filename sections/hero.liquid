<section class="hero">
  <div class="hero-left">
    <span class="hero-eyebrow">{{ section.settings.slogan | default: settings.slogan }}</span>
    <h1 class="hero-headline">{{ section.settings.headline }}</h1>
    <p class="hero-desc">{{ section.settings.subtext }}</p>
    <div class="hero-ctas">
      {%- if section.settings.cta_primary_url != blank -%}
        <a href="{{ section.settings.cta_primary_url }}" class="btn btn-primary btn-lg">
          {{ section.settings.cta_primary_label }}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_url != blank -%}
        <a href="{{ section.settings.cta_secondary_url }}" class="btn btn-outline-white">{{ section.settings.cta_secondary_label }}</a>
      {%- endif -%}
    </div>
    <div class="hero-trust">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_stat' -%}
            <div class="trust-item" {{ block.shopify_attributes }}>
              <div class="trust-num">{{ block.settings.number }}</div>
              <div class="trust-label">{{ block.settings.label }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <div class="trust-item">
          <div class="trust-num">60+</div>
          <div class="trust-label">Rackets verkocht</div>
        </div>
        <div class="trust-item">
          <div class="trust-num">3</div>
          <div class="trust-label">Topmerken</div>
        </div>
        <div class="trust-item">
          <div class="trust-num">≤50%</div>
          <div class="trust-label">Goedkoper dan nieuw</div>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="hero-right">
    {%- if section.settings.hero_image != blank -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1400 }}"
        alt="{{ section.settings.hero_image_alt | default: shop.name }}"
        style="position:absolute;top:0;left:0;right:0;bottom:0;width:100%;height:100%;object-fit:cover;display:block;"
        loading="eager">
    {%- else -%}
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:1rem;opacity:0.5;color:#2E69DD;">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <span style="font-size:0.85rem;font-weight:600;text-align:center;">Voeg een afbeelding toe<br>via de Shopify editor</span>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "slogan",
      "label": "Slogan (overschrijft globale instelling)"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Koptekst",
      "default": "Jouw eerste padel racket. Slim gekozen."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "Professioneel gereviseerde padelrackets van topmerken — voor een fractie van de nieuwprijs. Gecheckt, gereinigd en klaar om mee te spelen."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primaire knop tekst",
      "default": "Bekijk alle rackets"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primaire knop link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secundaire knop tekst",
      "default": "Ons verhaal"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secundaire knop link"
    },
    {
      "type": "header",
      "content": "Afbeelding rechts"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero afbeelding"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Alt tekst afbeelding",
      "default": "PadelRefurbished rackets"
    }
  ],
  "blocks": [
    {
      "type": "trust_stat",
      "name": "Vertrouwensgetal",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Getal",
          "default": "60+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Rackets verkocht"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "trust_stat", "settings": { "number": "60+", "label": "Rackets verkocht" } },
        { "type": "trust_stat", "settings": { "number": "3", "label": "Topmerken" } },
        { "type": "trust_stat", "settings": { "number": "≤50%", "label": "Goedkoper dan nieuw" } }
      ]
    }
  ]
}
{% endschema %}
