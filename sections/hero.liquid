<section class="hero">
  <div class="hero-left">
    <div class="hero-content">
      <div class="hero-eyebrow">{{ section.settings.slogan | default: settings.slogan }}</div>
      <h1 class="hero-title">{{ section.settings.headline }}</h1>
      <p class="hero-subtitle">{{ section.settings.subtext }}</p>
      <div class="hero-cta">
        {%- if section.settings.cta_primary_url != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="btn btn-primary btn-lg">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_url != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="btn btn-outline btn-lg">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>
      <div class="hero-trust">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_item' -%}
            <div class="trust-item" {{ block.shopify_attributes }}>
              <span class="trust-icon">{{ block.settings.icon }}</span>
              <span>{{ block.settings.text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="hero-right">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 800 }}" alt="Hero" class="hero-image">
    {%- else -%}
      <div class="hero-cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_card' -%}
            {%- assign prod = all_products[block.settings.product] -%}
            {%- if prod != empty -%}
              <a href="{{ prod.url }}" class="hero-product-card" {{ block.shopify_attributes }}>
                {%- if prod.featured_image -%}
                  <img src="{{ prod.featured_image | image_url: width: 300 }}" alt="{{ prod.title }}">
                {%- endif -%}
                <div class="hero-card-info">
                  <span class="hero-card-name">{{ prod.title }}</span>
                  <span class="hero-card-price">{{ prod.price | money }}</span>
                </div>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "slogan",
      "label": "Slogan (overschrijft globale instelling)"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Koptekst",
      "default": "Jouw eerste racket. Slimmer gekozen."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "Topkwaliteit refurbished padelrackets — duurzaam, betaalbaar en klaar voor de baan."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primaire knop tekst",
      "default": "Bekijk rackets"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primaire knop link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secundaire knop tekst",
      "default": "Ons verhaal"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secundaire knop link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero afbeelding (optioneel)"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Vertrouwensitem",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji icoon",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Tekst",
          "default": "Gratis verzending"
        }
      ]
    },
    {
      "type": "product_card",
      "name": "Product kaart",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "🚚", "text": "Gratis verzending v.a. €100" } },
        { "type": "trust_item", "settings": { "icon": "↩", "text": "14 dagen retour" } },
        { "type": "trust_item", "settings": { "icon": "♻", "text": "Duurzaam gecertificeerd" } }
      ]
    }
  ]
}
{% endschema %}
