<section class="contact-body section-py">
  <div class="container">
    <div class="contact-grid">

      <!-- Form -->
      <div class="contact-form-wrap">
        <h2>{{ section.settings.form_heading }}</h2>
        <p class="lead">{{ section.settings.form_subtext }}</p>

        {%- form 'contact', id: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="contact-success">
              <strong>✅ Bericht verstuurd!</strong><br>
              <span>We nemen binnen 24 uur contact met je op.</span>
            </div>
          {%- else -%}
            <div class="form-row">
              <div class="form-group">
                <label class="form-label" for="contact_name">Naam *</label>
                <input type="text" id="contact_name" name="contact[name]" class="form-input" required placeholder="Jouw naam">
              </div>
              <div class="form-group">
                <label class="form-label" for="contact_email">E-mailadres *</label>
                <input type="email" id="contact_email" name="contact[email]" class="form-input" required placeholder="jouw@email.nl">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact_subject">Onderwerp</label>
              <select id="contact_subject" name="contact[subject]" class="form-select">
                <option value="">Selecteer een onderwerp</option>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'subject' -%}
                    <option value="{{ block.settings.label | handleize }}">{{ block.settings.label }}</option>
                  {%- endif -%}
                {%- endfor -%}
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact_message">Bericht *</label>
              <textarea id="contact_message" name="contact[body]" class="form-textarea" required placeholder="Vertel ons hoe we je kunnen helpen..."></textarea>
            </div>
            <button type="submit" class="form-submit">{{ section.settings.button_label }}</button>
          {%- endif -%}
        {%- endform -%}
      </div>

      <!-- Sidebar -->
      <div class="contact-sidebar">

        <div class="response-badge">
          <div class="response-dot"></div>
          {{ section.settings.response_text }}
        </div>

        <div class="contact-info-card">
          <div class="contact-info-title">{{ section.settings.info_heading }}</div>
          <div class="contact-info-items">
            {%- if section.settings.email != blank -%}
              <div class="contact-info-item">
                <div class="ci-icon">📧</div>
                <div>
                  <div class="ci-label">E-mail</div>
                  <div class="ci-value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></div>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.phone != blank -%}
              <div class="contact-info-item">
                <div class="ci-icon">📞</div>
                <div>
                  <div class="ci-label">Telefoon / WhatsApp</div>
                  <div class="ci-value"><a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' }}">{{ section.settings.phone }}</a></div>
                </div>
              </div>
            {%- endif -%}
            {%- if section.settings.hours != blank -%}
              <div class="contact-info-item">
                <div class="ci-icon">⏰</div>
                <div>
                  <div class="ci-label">Bereikbaarheid</div>
                  <div class="ci-value">{{ section.settings.hours }}</div>
                </div>
              </div>
            {%- endif -%}
          </div>

          {%- if settings.instagram_url != blank or settings.linkedin_url != blank -%}
            <div class="social-contact">
              <div class="social-contact-label">Volg ons</div>
              <div class="social-contact-icons">
                {%- if settings.instagram_url != blank -%}
                  <a href="{{ settings.instagram_url }}" class="social-icon social-icon--light" target="_blank" rel="noopener" aria-label="Instagram">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                      <circle cx="12" cy="12" r="4"/>
                      <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
                    </svg>
                  </a>
                {%- endif -%}
                {%- if settings.linkedin_url != blank -%}
                  <a href="{{ settings.linkedin_url }}" class="social-icon social-icon--light" target="_blank" rel="noopener" aria-label="LinkedIn">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                      <rect x="2" y="9" width="4" height="12"/>
                      <circle cx="4" cy="4" r="2"/>
                    </svg>
                  </a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>

        <div class="contact-info-card quick-info-card">
          <div class="contact-info-title">{{ section.settings.quick_heading }}</div>
          <div class="quick-info-items">
            {%- if section.settings.quick_delivery != blank -%}
              <div class="quick-info-item">🚀 <strong>Levertijd:</strong> {{ section.settings.quick_delivery }}</div>
            {%- endif -%}
            {%- if section.settings.quick_shipping != blank -%}
              <div class="quick-info-item">📦 <strong>Verzendkosten:</strong> {{ section.settings.quick_shipping }}</div>
            {%- endif -%}
            {%- if section.settings.quick_return != blank -%}
              <div class="quick-info-item">🔄 <strong>Retour:</strong> {{ section.settings.quick_return }}</div>
            {%- endif -%}
            {%- if section.settings.quick_kvk != blank -%}
              <div class="quick-info-item">🏢 <strong>KVK:</strong> {{ section.settings.quick_kvk }}</div>
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contactformulier",
  "settings": [
    { "type": "text", "id": "form_heading", "label": "Formulier koptekst", "default": "Stuur een bericht" },
    { "type": "text", "id": "form_subtext", "label": "Formulier ondertekst", "default": "Vul het formulier in en we nemen zo snel mogelijk contact met je op." },
    { "type": "text", "id": "button_label", "label": "Verzendknop tekst", "default": "Verstuur bericht →" },
    { "type": "text", "id": "response_text", "label": "Reactietijd tekst", "default": "We reageren doorgaans binnen 24 uur" },
    { "type": "header", "content": "Direct contact" },
    { "type": "text", "id": "info_heading", "label": "Koptekst kaart", "default": "Direct contact" },
    { "type": "text", "id": "email", "label": "E-mailadres", "default": "info@padelrefurbished.nl" },
    { "type": "text", "id": "phone", "label": "Telefoonnummer", "default": "+31 6 13609094" },
    { "type": "text", "id": "hours", "label": "Bereikbaarheid", "default": "Ma–Vr, 09:00–18:00" },
    { "type": "header", "content": "Snelle info" },
    { "type": "text", "id": "quick_heading", "label": "Koptekst kaart", "default": "Snelle info" },
    { "type": "text", "id": "quick_delivery", "label": "Levertijd", "default": "Binnen 2 werkdagen" },
    { "type": "text", "id": "quick_shipping", "label": "Verzendkosten", "default": "€6,95 (gratis v.a. €100)" },
    { "type": "text", "id": "quick_return", "label": "Retourperiode", "default": "14 dagen bedenktijd" },
    { "type": "text", "id": "quick_kvk", "label": "KVK nummer", "default": "01166795" }
  ],
  "blocks": [
    {
      "type": "subject",
      "name": "Onderwerp optie",
      "settings": [
        { "type": "text", "id": "label", "label": "Onderwerp", "default": "Vraag over bestelling" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contactformulier",
      "blocks": [
        { "type": "subject", "settings": { "label": "Racket advies" } },
        { "type": "subject", "settings": { "label": "Vraag over mijn bestelling" } },
        { "type": "subject", "settings": { "label": "Retour aanvragen" } },
        { "type": "subject", "settings": { "label": "Overig" } }
      ]
    }
  ]
}
{% endschema %}
