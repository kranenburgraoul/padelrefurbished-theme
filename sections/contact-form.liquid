<section class="contact-page section">
  <div class="container">
    <div class="contact-layout">
      <!-- Form -->
      <div class="contact-form-wrap" data-reveal>
        <h2>{{ section.settings.form_heading }}</h2>
        {%- form 'contact', id: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="form-success">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Bedankt! We nemen zo snel mogelijk contact met je op.
            </div>
          {%- else -%}
            <div class="form-row-2">
              <div class="form-group">
                <label for="contact_name">Naam</label>
                <input type="text" id="contact_name" name="contact[name]" class="input" required placeholder="Jouw naam">
              </div>
              <div class="form-group">
                <label for="contact_email">E-mail</label>
                <input type="email" id="contact_email" name="contact[email]" class="input" required placeholder="jouw@email.nl">
              </div>
            </div>
            <div class="form-group">
              <label for="contact_subject">Onderwerp</label>
              <select id="contact_subject" name="contact[subject]" class="input">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'subject' -%}
                    <option>{{ block.settings.label }}</option>
                  {%- endif -%}
                {%- endfor -%}
              </select>
            </div>
            <div class="form-group">
              <label for="contact_message">Bericht</label>
              <textarea id="contact_message" name="contact[body]" class="input" rows="6" required placeholder="Schrijf hier je bericht…"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-lg">
              {{ section.settings.button_label }}
            </button>
          {%- endif -%}
        {%- endform -%}
      </div>

      <!-- Sidebar -->
      <div class="contact-sidebar" data-reveal>
        <div class="contact-info-card">
          <h3>{{ section.settings.info_heading }}</h3>
          {%- if section.settings.email != blank -%}
            <div class="contact-info-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
            </div>
          {%- endif -%}
          {%- if section.settings.response_time != blank -%}
            <p class="contact-response">{{ section.settings.response_time }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.faq_heading != blank -%}
          <div class="faq-block">
            <h3>{{ section.settings.faq_heading }}</h3>
            {%- for block in section.blocks -%}
              {%- if block.type == 'faq' -%}
                <div class="accordion-item" {{ block.shopify_attributes }}>
                  <button class="accordion-trigger">{{ block.settings.question }}</button>
                  <div class="accordion-content">
                    <p>{{ block.settings.answer }}</p>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contactformulier",
  "settings": [
    {
      "type": "text",
      "id": "form_heading",
      "label": "Formulier koptekst",
      "default": "Stuur ons een bericht"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Verzendknop tekst",
      "default": "Bericht versturen"
    },
    {
      "type": "text",
      "id": "info_heading",
      "label": "Info koptekst",
      "default": "Contact informatie"
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-mailadres"
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "Reactietijd tekst",
      "default": "We reageren doorgaans binnen 24 uur op werkdagen."
    },
    {
      "type": "text",
      "id": "faq_heading",
      "label": "FAQ koptekst",
      "default": "Veelgestelde vragen"
    }
  ],
  "blocks": [
    {
      "type": "subject",
      "name": "Onderwerp optie",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Onderwerp",
          "default": "Vraag over bestelling"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ vraag",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Vraag",
          "default": "Hoe lang duurt verzending?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Antwoord",
          "default": "We verzenden binnen 1-2 werkdagen. Levering duurt daarna 1-2 werkdagen."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contactformulier",
      "blocks": [
        { "type": "subject", "settings": { "label": "Vraag over bestelling" } },
        { "type": "subject", "settings": { "label": "Vraag over een product" } },
        { "type": "subject", "settings": { "label": "Retour of ruil" } },
        { "type": "subject", "settings": { "label": "Samenwerking" } },
        { "type": "subject", "settings": { "label": "Overige" } },
        { "type": "faq", "settings": { "question": "Hoe lang duurt verzending?", "answer": "We verzenden binnen 1-2 werkdagen. Levering duurt daarna nog 1-2 werkdagen via PostNL." } },
        { "type": "faq", "settings": { "question": "Kan ik een racket retourneren?", "answer": "Ja, je hebt 14 dagen retourrecht. Neem contact op en we regelen het verder." } },
        { "type": "faq", "settings": { "question": "Zijn de rackets gegarandeerd speelklaar?", "answer": "Elk racket wordt professioneel geïnspecteerd en hersteld voor verzending." } }
      ]
    }
  ]
}
{% endschema %}
