<section class="cta-banner">
  <div class="container">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
    <div class="cta-banner-actions">
      {%- if section.settings.cta_primary_url != blank -%}
        <a href="{{ section.settings.cta_primary_url }}" class="btn btn-primary btn-lg">{{ section.settings.cta_primary_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_url != blank -%}
        <a href="{{ section.settings.cta_secondary_url }}" class="btn btn-outline-white btn-lg">{{ section.settings.cta_secondary_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Klaar om te beginnen met padelen?"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "Kies jouw refurbished racket en start vandaag nog."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primaire knop tekst",
      "default": "Bekijk alle rackets"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primaire knop link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secundaire knop tekst",
      "default": "Hulp nodig? Vraag het ons"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secundaire knop link"
    }
  ],
  "presets": [
    {
      "name": "CTA banner"
    }
  ]
}
{% endschema %}
