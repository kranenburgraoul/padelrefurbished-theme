<header class="site-header" role="banner">
  <div class="container header-inner">
    <a href="{{ routes.root_url }}" class="logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="160" height="40">
      {%- else -%}
        <span class="logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="main-nav" data-nav-menu aria-label="Hoofdnavigatie">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}" class="nav-link{% if link.active %} active{% endif %}">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="header-actions">
      <a href="{{ routes.cart_url }}" class="cart-icon" aria-label="Winkelmandje">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-count" style="display:none">0</span>
      </a>
      <button class="mobile-nav-toggle" data-nav-toggle aria-expanded="false" aria-label="Menu openen">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigatiemenu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
