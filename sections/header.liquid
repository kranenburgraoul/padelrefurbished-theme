<nav class="navbar">
  <div class="navbar-inner">
    <a href="{{ routes.root_url }}" class="navbar-logo">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="160" height="40" style="height:36px;width:auto;">
      {%- else -%}
        Padel<span>Refurbished</span>
      {%- endif -%}
    </a>

    <ul class="navbar-nav">
      {%- for link in linklists[section.settings.menu].links -%}
        <li>
          <a href="{{ link.url }}"{% if link.active %} class="active" aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>

    <div class="navbar-actions">
      <a href="{{ routes.cart_url }}" class="cart-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        Winkelwagen
        <span class="cart-count" style="display:none">0</span>
      </a>
      <button class="mobile-nav-toggle" data-nav-toggle aria-expanded="false" aria-label="Menu openen">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigatiemenu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
