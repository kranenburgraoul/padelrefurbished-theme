<div class="stats-bar">
  <div class="stats-inner">
    {%- for block in section.blocks -%}
      <div class="stat-item" {{ block.shopify_attributes }}>
        <div class="stat-icon">{{ block.settings.icon }}</div>
        <div>
          <strong class="stat-strong">{{ block.settings.strong }}</strong>
          <span class="stat-small">{{ block.settings.small }}</span>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Statistieken balk",
  "blocks": [
    {
      "type": "stat",
      "name": "Statistiek",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Emoji icoon",
          "default": "✅"
        },
        {
          "type": "text",
          "id": "strong",
          "label": "Vetgedrukte tekst",
          "default": "100% Gecheckt"
        },
        {
          "type": "text",
          "id": "small",
          "label": "Klein tekst",
          "default": "Elk racket persoonlijk geïnspecteerd"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Statistieken balk",
      "blocks": [
        { "type": "stat", "settings": { "icon": "✅", "strong": "100% Gecheckt", "small": "Elk racket persoonlijk geïnspecteerd" } },
        { "type": "stat", "settings": { "icon": "🚀", "strong": "Binnen 2 werkdagen", "small": "Snelle levering door heel Nederland" } },
        { "type": "stat", "settings": { "icon": "🛡️", "strong": "14 dagen retour", "small": "Niet tevreden? Geld terug, geen vragen" } },
        { "type": "stat", "settings": { "icon": "♻️", "strong": "Duurzaam", "small": "Minder afval, meer padel" } }
      ]
    }
  ]
}
{% endschema %}
