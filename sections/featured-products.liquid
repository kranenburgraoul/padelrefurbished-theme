<section class="featured-section">
  <div class="container">
    <div class="featured-header">
      <div>
        <div class="section-label">{{ section.settings.eyebrow }}</div>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="btn btn-outline">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="products-grid">
      {%- if section.settings.collection != blank -%}
        {%- assign col = collections[section.settings.collection] -%}
        {%- for product in col.products limit: section.settings.products_count -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'product' -%}
            {%- assign product = all_products[block.settings.product] -%}
            {%- if product != empty -%}
              {%- render 'product-card', product: product -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Uitgelichte producten",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Label boven titel",
      "default": "Aanbevolen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Populaire rackets"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collectie (automatisch invullen)"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Aantal producten",
      "default": 4
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Knop tekst",
      "default": "Alle rackets →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knop link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Uitgelichte producten"
    }
  ]
}
{% endschema %}
