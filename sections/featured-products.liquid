<section class="featured-products section">
  <div class="container">
    <div class="section-header" data-reveal>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subtext }}</p>
    </div>

    <div class="products-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {%- assign prod = all_products[block.settings.product] -%}
          {%- if prod != empty -%}
            {%- render 'product-card', product: prod, block: block -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.collection != blank -%}
        {%- assign col = collections[section.settings.collection] -%}
        {%- for prod in col.products limit: section.settings.products_count -%}
          {%- render 'product-card', product: prod -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.cta_url != blank -%}
      <div class="section-cta" data-reveal>
        <a href="{{ section.settings.cta_url }}" class="btn btn-primary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Uitgelichte producten",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Populaire rackets"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Ondertekst",
      "default": "Handgeselecteerd voor starters en gevorderden"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collectie (automatisch)"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Aantal producten",
      "default": 4
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Knop tekst",
      "default": "Alle rackets bekijken"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knop link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Specifiek product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Uitgelichte producten"
    }
  ]
}
{% endschema %}
