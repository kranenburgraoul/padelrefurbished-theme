              <rect x="27" y="50" width="6" height="24" rx="3" fill="#0F2D87" opacity="0.5"/>
              <rect x="19" y="72" width="22" height="5" rx="2.5" fill="#0F2D87" opacity="0.4"/>
            </svg>
          </div>
          <div class="product-body">
            <div class="product-brand">HEAD</div>
            <div class="product-name">Zephyr</div>
            <div class="product-tags"><span class="product-tag">Starter</span><span class="product-tag">Licht gewicht</span></div>
            <div class="product-footer">
              <div class="product-price-wrap"><span class="product-price">€75</span><span class="product-price-original">€169</span></div>
              <button class="add-to-cart-btn">+ Voeg toe</button>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Uitgelichte producten",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Label boven titel",
      "default": "Aanbevolen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Populaire rackets"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collectie (koppel hier je rackets)"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Aantal producten",
      "default": 4
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Knop tekst",
      "default": "Alle rackets →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Knop link"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Uitgelichte producten"
    }
  ]
}
{% endschema %}
