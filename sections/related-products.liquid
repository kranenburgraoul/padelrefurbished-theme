{%- if product.collections.first -%}
  {%- assign related = product.collections.first.products -%}
  {%- assign has_related = false -%}
  {%- for p in related -%}
    {%- unless p.id == product.id -%}
      {%- assign has_related = true -%}
    {%- endunless -%}
  {%- endfor -%}

  {%- if has_related -%}
    <section class="related-products section">
      <div class="container">
        <div class="section-header" data-reveal>
          <h2 class="section-title">{{ section.settings.heading }}</h2>
        </div>
        <div class="products-grid">
          {%- for p in related limit: 4 -%}
            {%- unless p.id == product.id -%}
              {%- render 'product-card', product: p -%}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Gerelateerde producten",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Misschien ook interessant"
    }
  ],
  "presets": [
    {
      "name": "Gerelateerde producten"
    }
  ]
}
{% endschema %}
