<section class="about-mission section">
  <div class="container">
    <div class="about-mission__inner" data-reveal>
      {%- if section.settings.image != blank -%}
        <div class="about-mission__image">
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
        </div>
      {%- endif -%}
      <div class="about-mission__text">
        <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <div class="about-mission__body">{{ section.settings.body }}</div>
        <div class="impact-numbers">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="impact-stat" {{ block.shopify_attributes }}>
                <div class="impact-number">{{ block.settings.number }}</div>
                <div class="impact-label">{{ block.settings.label }}</div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Missie sectie",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkoptekst",
      "default": "Onze missie"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Padel toegankelijk maken voor iedereen"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Tekst"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Impact getal",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Getal",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Rackets gered"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Missie sectie",
      "blocks": [
        { "type": "stat", "settings": { "number": "500+", "label": "Rackets gered" } },
        { "type": "stat", "settings": { "number": "2x", "label": "Leven verlengd" } },
        { "type": "stat", "settings": { "number": "98%", "label": "Tevreden klanten" } }
      ]
    }
  ]
}
{% endschema %}
