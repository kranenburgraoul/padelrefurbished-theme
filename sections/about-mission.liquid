<section class="about-mission section">
  <div class="container">
    <div class="about-mission__inner">
      <div class="about-mission__image">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
        {%- else -%}
          <span class="about-mission__placeholder">PR</span>
        {%- endif -%}
      </div>
      <div class="about-mission__text">
        <div class="section-eyebrow">{{ section.settings.eyebrow | default: 'Onze missie' }}</div>
        <h2 class="section-title">{{ section.settings.heading | default: 'Padel toegankelijk maken voor iedereen' }}</h2>
        <div class="about-mission__body">
          {%- if section.settings.body != blank -%}
            {{ section.settings.body }}
          {%- else -%}
            <p>PadelRefurbished is opgericht door vier studenten met een passie voor padel en duurzaamheid. We geloven dat een goed racket geen fortuin hoeft te kosten — en dat elk racket een tweede kans verdient.</p>
            <p>Door professioneel refurbishen geven wij gebruikte rackets een nieuw leven. Zo besparen spelers geld en bespaart de planeet grondstoffen.</p>
          {%- endif -%}
        </div>
        <div class="impact-numbers">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'stat' -%}
                <div class="impact-stat" {{ block.shopify_attributes }}>
                  <div class="impact-number">{{ block.settings.number }}</div>
                  <div class="impact-label">{{ block.settings.label }}</div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <div class="impact-stat">
              <div class="impact-number" style="font-size:2rem;font-weight:800;color:#2E69DD;">500+</div>
              <div class="impact-label">Rackets gered</div>
            </div>
            <div class="impact-stat">
              <div class="impact-number" style="font-size:2rem;font-weight:800;color:#2E69DD;">2x</div>
              <div class="impact-label">Leven verlengd</div>
            </div>
            <div class="impact-stat">
              <div class="impact-number" style="font-size:2rem;font-weight:800;color:#2E69DD;">98%</div>
              <div class="impact-label">Tevreden klanten</div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Missie sectie",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Bovenkoptekst",
      "default": "Onze missie"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Koptekst",
      "default": "Padel toegankelijk maken voor iedereen"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Tekst"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Afbeelding"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Impact getal",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Getal",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Rackets gered"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Missie sectie",
      "blocks": [
        { "type": "stat", "settings": { "number": "500+", "label": "Rackets gered" } },
        { "type": "stat", "settings": { "number": "2x", "label": "Leven verlengd" } },
        { "type": "stat", "settings": { "number": "98%", "label": "Tevreden klanten" } }
      ]
    }
  ]
}
{% endschema %}
