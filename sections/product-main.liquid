{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="container">
  <nav class="breadcrumb" aria-label="Kruimelpad">
    <a href="{{ routes.root_url }}">Home</a>
    <span>›</span>
    <a href="{{ collection.url | default: routes.collections_url }}">Rackets</a>
    <span>›</span>
    <span>{{ product.title }}</span>
  </nav>

  <div class="product-layout">
    <!-- Gallery -->
    <div class="product-gallery">
      <div class="gallery-main">
        <span class="gallery-badge">{{ product.metafields.custom.condition | default: 'Refurbished' }}</span>
        {%- if product.featured_image -%}
          <img id="gallery-main-img" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}">
        {%- else -%}
          <svg class="no-image" viewBox="0 0 60 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="10" y="2" width="40" height="48" rx="20" fill="currentColor" opacity="0.3"/>
            <line x1="15" y1="14" x2="45" y2="14" stroke="currentColor" stroke-width="1.5" opacity="0.25"/>
            <line x1="15" y1="22" x2="45" y2="22" stroke="currentColor" stroke-width="1.5" opacity="0.25"/>
            <line x1="32" y1="3" x2="32" y2="48" stroke="currentColor" stroke-width="1.5" opacity="0.25"/>
            <rect x="27" y="50" width="6" height="24" rx="3" fill="currentColor" opacity="0.4"/>
          </svg>
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="gallery-thumbs">
          {%- for img in product.images limit: 4 -%}
            <div class="gallery-thumb {% if forloop.first %}active{% endif %}" data-src="{{ img | image_url: width: 800 }}">
              <img src="{{ img | image_url: width: 120 }}" alt="{{ product.title | escape }} {{ forloop.index }}" loading="lazy">
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Info -->
    <div class="product-info">
      <div class="product-brand-row">
        <span class="product-brand-badge">{{ product.vendor }}</span>
      </div>
      <h1 class="product-title">{{ product.title }}</h1>

      <div class="price-block">
        <span class="price-now">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="price-was">{{ current_variant.compare_at_price | money }}</span>
          {%- assign savings = current_variant.compare_at_price | minus: current_variant.price -%}
          <span class="price-save">-{{ savings | money }}</span>
        {%- endif -%}
      </div>
      <p class="price-note">Inclusief BTW · {{ settings.free_shipping_threshold | prepend: 'Gratis verzending v.a. €' }}</p>

      <hr class="divider">

      {%- assign mf_kleur  = product.metafields.custom.kleur.value -%}
      {%- assign mf_vorm   = product.metafields.custom.vorm.value -%}
      {%- assign mf_balans = product.metafields.custom.balans.value -%}
      {%- if mf_kleur != blank or mf_vorm != blank or mf_balans != blank -%}
        <div class="product-specs">
          {%- if mf_kleur != blank -%}
            <div class="spec-item">
              <span class="spec-label">Kleur</span>
              <span class="spec-value">{{ mf_kleur }}</span>
            </div>
          {%- endif -%}
          {%- if mf_vorm != blank -%}
            <div class="spec-item">
              <span class="spec-label">Vorm</span>
              <span class="spec-value">{{ mf_vorm }}</span>
            </div>
          {%- endif -%}
          {%- if mf_balans != blank -%}
            <div class="spec-item">
              <span class="spec-label">Balans</span>
              <span class="spec-value">{{ mf_balans }}</span>
            </div>
          {%- endif -%}
        </div>
        <hr class="divider">
      {%- endif -%}

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="grip-section">
            <span class="grip-label">{{ option.name }}</span>
            <div class="grip-options">
              {%- for value in option.values -%}
                <button class="grip-option {% if option.selected_value == value %}active{% endif %}"
                  data-option-group="{{ option.name | handleize }}"
                  data-option-position="{{ option.position }}"
                  data-option-value="{{ value | escape }}">
                  {{ value }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
        <hr class="divider">
      {%- endunless -%}

      {%- form 'product', product, id: 'product-form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <div class="cart-section">
          {%- if product.available -%}
            <button type="submit" class="cart-main-btn"
              data-add-to-cart="{{ current_variant.id }}"
              data-product-title="{{ product.title | escape }}"
              data-variant-id="{{ current_variant.id }}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
              In winkelmandje
            </button>
          {%- else -%}
            <button type="button" class="cart-main-btn" style="background:#9CA3AF;cursor:not-allowed;" disabled>Uitverkocht</button>
          {%- endif -%}
        </div>
      {%- endform -%}

      <div class="shipping-info">
        <div class="shipping-row">
          <span class="shipping-icon">🚚</span>
          Gratis verzending v.a. {{ settings.free_shipping_threshold | prepend: '€' }}
        </div>
        <div class="shipping-row">
          <span class="shipping-icon">↩</span>
          {{ settings.return_days }} dagen retour
        </div>
        <div class="shipping-row">
          <span class="shipping-icon">🔍</span>
          Professioneel geïnspecteerd
        </div>
      </div>

      {%- if product.description != blank -%}
        <div class="product-accordion">
          <div class="acc-item">
            <div class="acc-trigger accordion-trigger">
              Productomschrijving
              <svg class="acc-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="acc-body accordion-content">
              <div class="acc-content">{{ product.description }}</div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product detail",
  "settings": [],
  "presets": [
    { "name": "Product detail" }
  ]
}
{% endschema %}
